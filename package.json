{
  "name": "jsonl-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JSON Lines / NDJSON core library, CLI, and language server, with editor integrations.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm test --workspaces && npm run test:editors",
    "test:editors": "node --test \"editors/bbedit/test/*.test.js\"",
    "test:module": "make -C editors/bbedit/module test"
  },
  "engines": {
    "node": ">=20"
  }
}
