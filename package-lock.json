{
  "name": "jsonl-tools",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "jsonl-tools",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@sarvagnan/jsonl-cli": {
      "resolved": "packages/jsonl-cli",
      "link": true
    },
    "node_modules/@sarvagnan/jsonl-core": {
      "resolved": "packages/jsonl-core",
      "link": true
    },
    "node_modules/@sarvagnan/jsonl-lsp": {
      "resolved": "packages/jsonl-lsp",
      "link": true
    },
    "packages/jsonl-cli": {
      "name": "@sarvagnan/jsonl-cli",
      "version": "0.1.0",
      "license": "0BSD",
      "dependencies": {
        "@sarvagnan/jsonl-core": "^0.1.0"
      },
      "bin": {
        "jsonl": "bin/jsonl.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/jsonl-core": {
      "name": "@sarvagnan/jsonl-core",
      "version": "0.1.0",
      "license": "0BSD",
      "engines": {
        "node": ">=20"
      }
    },
    "packages/jsonl-lsp": {
      "name": "@sarvagnan/jsonl-lsp",
      "version": "0.1.0",
      "license": "0BSD",
      "dependencies": {
        "@sarvagnan/jsonl-core": "^0.1.0"
      },
      "bin": {
        "jsonl-lsp": "bin/jsonl-lsp.js"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
